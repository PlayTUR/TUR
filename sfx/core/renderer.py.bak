import pygame
import os

class CursesRenderer:
    # Kept name CursesRenderer temporarily to minimize refactor, or we can just rename it. 
    # Let's keep it compatible API-wise but logic is Pygame.
    def __init__(self, ref_w=1024, ref_h=768):
        self.ref_w = ref_w
        self.ref_h = ref_h
        
        # Fonts
        # Try finding a retro font, else monospace
        self.font_path = os.path.join("assets", "font.ttf")
        if os.path.exists(self.font_path):
             self.font = pygame.font.Font(self.font_path, 20)
             self.big_font = pygame.font.Font(self.font_path, 40)
        else:
             # Try common pixel fonts if available or standard monospace
             # 'pressstart2p', 'vt323', 'monospace', 'couriernew'
             self.font = pygame.font.SysFont("monospace", 20, bold=True)
             self.big_font = pygame.font.SysFont("monospace", 40, bold=True)
             
        # Cache key states
        self.key_states = [False] * 4

    def update_dimensions(self):
        # Window resize logic if needed, simplified for fixed res
        pass

    def clear(self):
        # Main loop handles fill
        pass

    def present(self):
        # Main loop handles flip
        pass

    def draw_text(self, surface, text, x, y, color=(255, 255, 255), font=None):
        if not font: font = self.font
        if not surface: return # Should not happen in pure pygame mode unless bug
        
        # TUI Look: Drop shadow?
        # shadow = font.render(str(text), False, (0, 50, 0))
        # surface.blit(shadow, (x+2, y+2))
        
        # AA = False for pixelated look
        surf = font.render(str(text), False, color)
        surface.blit(surf, (x, y))

    def draw_lanes(self, surface, upscroll=False):
        # Draw 4 Lanes
        center_x = self.ref_w // 2
        lane_w = 100 # Pixels
        start_x = center_x - (lane_w * 2)
        
        # Draw Background for track
        pygame.draw.rect(surface, (10, 20, 10), (start_x, 0, lane_w * 4, self.ref_h))
        
        # Lane Dividers
        for i in range(5):
            x = start_x + i * lane_w
            pygame.draw.line(surface, (50, 100, 50), (x, 0), (x, self.ref_h), 2)
            
        # Receptor Line
        hit_y = int(self.ref_h * (0.15 if upscroll else 0.85))
        pygame.draw.line(surface, (200, 255, 200), (start_x, hit_y), (start_x + lane_w * 4, hit_y), 4)
        
        # Key receptors
        for i in range(4):
            x = start_x + i * lane_w
            # Draw empty circle or box
            rect = pygame.Rect(x + 10, hit_y - 20, lane_w - 20, 40)
            if self.key_states[i]:
                 pygame.draw.rect(surface, (100, 255, 100), rect)
            else:
                 pygame.draw.rect(surface, (50, 100, 50), rect, 2)

    def draw_notes(self, surface, notes, song_time, scroll_speed, upscroll=False):
        # speed: pixels per second. 
        # Default speed 500 is good.
        
        center_x = self.ref_w // 2
        lane_w = 100
        start_x = center_x - (lane_w * 2)
        
        hit_y = int(self.ref_h * (0.15 if upscroll else 0.85))
        
        for note in notes:
            if note.get('hit', False): continue
            
            dt = note['time'] - song_time
            # Standard view window: -0.2 to +2.0s roughly
            if dt < -0.2 or dt > 3.0: continue
            
            dy = int(dt * scroll_speed)
            
            y = hit_y + dy if upscroll else hit_y - dy
            x = start_x + note['lane'] * lane_w
            
            # Note is a Rect or Circle? User wants TUI style.
            # "[ ]" or "( )"?
            # Let's draw a nice filled box with character on it?
            
            if -50 < y < self.ref_h + 50:
                 col = (100, 200, 255)
                 if note['lane'] in [0, 3]: col = (255, 100, 100) # Red outer
                 else: col = (100, 200, 255) # Blue inner
                 
                 rect = pygame.Rect(x + 10, y - 20, lane_w - 20, 40)
                 pygame.draw.rect(surface, col, rect)
                 pygame.draw.rect(surface, (255,255,255), rect, 2)

    def draw_effects(self, surface):
        pass
    
    def add_hit_effect(self, text, lane):
        pass # Todo: add particle system or floating text
